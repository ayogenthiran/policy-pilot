# OpenAI (required for ingest + RAG)
OPENAI_API_KEY=

# Models
EMBEDDING_MODEL=text-embedding-3-small
CHAT_MODEL=gpt-4o-mini

# RAG
RAG_TOP_K=5

# Chunking (ingestion)
CHUNK_SIZE=1200
CHUNK_OVERLAP=200

# Weaviate (docker-compose — HTTP 8080, gRPC 50051)
WEAVIATE_HTTP_HOST=localhost
WEAVIATE_HTTP_PORT=8080
WEAVIATE_HTTP_SECURE=false
# Leave empty to reuse HTTP host
WEAVIATE_GRPC_HOST=
WEAVIATE_GRPC_PORT=50051
WEAVIATE_GRPC_SECURE=false
# WEAVIATE_API_KEY=

# Default collection slug → Weaviate class name via policy_pilot.vectordb.library_class_name
COLLECTION_SLUG=policy_documents
